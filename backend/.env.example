# ==========================================
# WutheringWavesDPS 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ==========================================

# JWT密钥 - 必须设置！使用随机生成的强密钥
# 生成方法: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-this-to-a-random-string

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password
# 或者使用密码哈希（推荐）
# ADMIN_PASSWORD_HASH=$2b$12$...

# 数据库配置（可选，默认使用SQLite）
# DATABASE_URL=sqlite:///./wuwa_calc.db

# Redis配置（可选）
# REDIS_URL=redis://localhost:6379/0

# 文件上传配置
MAX_UPLOAD_SIZE=52428800

# MinIO配置（可选，用于生产环境文件存储）
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET_NAME=wuwa-calc-files
# MINIO_SECURE=false
