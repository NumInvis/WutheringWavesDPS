# Application
APP_NAME=WutheringWavesDPS
APP_ENV=development
APP_DEBUG=true

# Database
DATABASE_URL=sqlite:///./wuwa_calc.db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin account
ADMIN_USERNAME=15171587952
# Use either plain password or bcrypt hash (preferred for storage).
# ADMIN_PASSWORD=change-me
# ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_SINGLETON=true
ADMIN_FORCE_PASSWORD=true

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Uploads
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# Action data (optional override)
# ACTION_DATA_PATH=D:/素材/鸣潮动作数据汇总.xlsx
# PULL_TABLE_ROOT=D:/素材
