# 应用配置
APP_NAME=鸣潮排轴DPS计算器
APP_ENV=development
APP_DEBUG=true

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/wuwa_calc

# Redis配置
REDIS_URL=redis://localhost:6379

# JWT配置
SECRET_KEY=your-super-secret-key-here-change-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
